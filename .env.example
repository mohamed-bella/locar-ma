# ---- Supabase (DB + Auth) ----
# Public (safe for browser, must be prefixed VITE_)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-only. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Cloudflare R2 (file storage) ----
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
# PUBLIC bucket — non-sensitive assets only (vehicle photos, brand/agency logos).
R2_BUCKET=locar
# Public base URL of the public bucket (custom domain or r2.dev).
R2_PUBLIC_URL=https://files.locar.ma
# PRIVATE bucket — sensitive documents (contract PDFs w/ client PII, ID scans).
# MUST have NO public access; files are served only via short-lived signed URLs.
# If unset, falls back to R2_BUCKET (NOT safe for production).
R2_DOCS_BUCKET=locar-docs

# ---- WhatsApp (Meta Cloud API) — Phase 4 ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
