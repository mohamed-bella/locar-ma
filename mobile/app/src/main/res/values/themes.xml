<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/navy</item>
        <item name="colorPrimaryDark">@color/status_bar</item>
        <item name="colorAccent">@color/blue_action</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/muted</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeSoftSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeSoftMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeSoftLarge</item>
        <item name="materialButtonStyle">@style/AppButton</item>
    </style>

    <style name="ShapeSoftSmall" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeSoftMedium" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeSoftLarge" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="AppButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ToolbarStyle" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/navy</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">#aadfff</item>
    </style>

    <style name="ContractFormSection">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/navy</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:drawableStart">@drawable/ic_contract</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:drawableTint">@color/navy</item>
    </style>

    <style name="ContractFormInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ContractFormDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginVertical">12dp</item>
        <item name="android:background">@color/divider</item>
    </style>

</resources>
