<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/navy</item>
        <item name="colorPrimaryDark">@color/status_bar</item>
        <item name="colorAccent">@color/blue_action</item>
        <item name="colorSecondary">@color/booking_yellow</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorError">@color/red</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/muted</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/navy_dark</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeSoftSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeSoftMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeSoftLarge</item>
        <item name="materialButtonStyle">@style/AppButton</item>
    </style>

    <style name="ShapeSoftSmall" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeSoftMedium" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeSoftLarge" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="AppButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="AppCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ScreenTitle">
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SectionLabel">
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="ContractFormInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:inputType">text</item>
        <item name="android:importantForAutofill">no</item>
    </style>

</resources>
