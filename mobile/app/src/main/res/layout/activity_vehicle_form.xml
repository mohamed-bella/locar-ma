<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/navy"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Voiture"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Photos ──────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_eye"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/navy"
                        android:gravity="center_vertical"
                        android:letterSpacing="0.08"
                        android:text="PHOTOS"
                        android:textColor="@color/navy"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/imageContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="90dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical" />
                    </HorizontalScrollView>

                    <Button
                        android:id="@+id/addImageButton"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="@color/navy"
                        android:text="+ Ajouter photos"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <ProgressBar
                        android:id="@+id/imageProgress"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="6dp"
                        android:indeterminateTint="@color/navy"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_car"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/navy"
                        android:gravity="center_vertical"
                        android:letterSpacing="0.08"
                        android:text="IDENTITE"
                        android:textColor="@color/navy"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/plate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/input_bg"
                        android:hint="Immatriculation"
                        android:inputType="textCapCharacters"
                        android:paddingHorizontal="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/brand"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="Marque"
                            android:inputType="textCapWords"
                            android:paddingHorizontal="12dp" />

                        <EditText
                            android:id="@+id/model"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="Modele"
                            android:inputType="textCapWords"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/year"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="Annee"
                            android:inputType="number"
                            android:paddingHorizontal="12dp" />

                        <EditText
                            android:id="@+id/dailyRate"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="DH / jour"
                            android:inputType="numberDecimal"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/category"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:paddingHorizontal="8dp" />

                    <Spinner
                        android:id="@+id/status"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:paddingHorizontal="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_suivi"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/navy"
                        android:gravity="center_vertical"
                        android:letterSpacing="0.08"
                        android:text="EXPLOITATION"
                        android:textColor="@color/navy"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/mileage"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/input_bg"
                        android:hint="Kilometrage actuel"
                        android:inputType="number"
                        android:paddingHorizontal="12dp" />

                    <EditText
                        android:id="@+id/insuranceExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="Expiration assurance"
                        android:paddingHorizontal="12dp" />

                    <EditText
                        android:id="@+id/vignetteExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="Expiration vignette"
                        android:paddingHorizontal="12dp" />

                    <EditText
                        android:id="@+id/visiteTechExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="Expiration visite technique"
                        android:paddingHorizontal="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/oilLastKm"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="Derniere vidange km"
                            android:inputType="number"
                            android:paddingHorizontal="12dp" />

                        <EditText
                            android:id="@+id/oilIntervalKm"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="Intervalle km"
                            android:inputType="number"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/oilLastDate"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:clickable="true"
                        android:focusable="false"
                        android:hint="Date derniere vidange"
                        android:paddingHorizontal="12dp" />

                    <EditText
                        android:id="@+id/nextServiceNote"
                        android:layout_width="match_parent"
                        android:layout_height="74dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:gravity="top"
                        android:hint="Prochain suivi / rappel"
                        android:padding="12dp" />

                    <EditText
                        android:id="@+id/notes"
                        android:layout_width="match_parent"
                        android:layout_height="86dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:gravity="top"
                        android:hint="Notes internes"
                        android:padding="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/blue_action"
                android:text="@string/save"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:indeterminateTint="@color/navy"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
