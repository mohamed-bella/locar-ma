<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="3dp"
    android:layout_marginBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="true"
        android:layout_marginBottom="2dp">

        <TextView
            android:id="@+id/fieldFr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/pdf_navy"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/fieldAr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="@color/pdf_muted"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/fieldValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/pdf_value_box"
        android:paddingHorizontal="5dp"
        android:paddingVertical="4dp"
        android:minHeight="22dp"
        android:gravity="center_vertical"
        android:textColor="@color/pdf_ink"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
