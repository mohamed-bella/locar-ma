<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/navy"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/new_contract"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/ContractFormSection"
                android:text="RESERVATION" />

            <Spinner
                android:id="@+id/reservationSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/input_bg" />

            <View style="@style/ContractFormDivider" />

            <TextView
                style="@style/ContractFormSection"
                android:text="VEHICULE DEPART" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/mileageOut"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:hint="Km depart"
                    android:inputType="number" />

                <Spinner
                    android:id="@+id/fuelOut"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg" />
            </LinearLayout>

            <View style="@style/ContractFormDivider" />

            <TextView
                style="@style/ContractFormSection"
                android:text="IDENTITE CLIENT" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/clientNom"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:hint="Nom" />

                <EditText
                    android:id="@+id/clientPrenom"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:hint="Prenom" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/clientCinExpiry"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Expiration CIN" />

                <EditText
                    android:id="@+id/clientBirthdate"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Naissance" />
            </LinearLayout>

            <EditText
                android:id="@+id/clientVille"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Ville" />

            <EditText
                android:id="@+id/clientPhone2"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Telephone 2"
                android:inputType="phone" />

            <EditText
                android:id="@+id/clientProfession"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Profession" />

            <View style="@style/ContractFormDivider" />

            <TextView
                style="@style/ContractFormSection"
                android:text="PERMIS CLIENT" />

            <EditText
                android:id="@+id/permitNumber"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Numero permis" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/permitDate"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Date permis" />

                <EditText
                    android:id="@+id/permitPlace"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:hint="Lieu" />
            </LinearLayout>

            <View style="@style/ContractFormDivider" />

            <TextView
                style="@style/ContractFormSection"
                android:text="2EME CONDUCTEUR OPTIONNEL" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/d2Name"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:hint="Nom" />

                <EditText
                    android:id="@+id/d2Prenom"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:hint="Prenom" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/d2Cin"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:hint="CIN" />

                <EditText
                    android:id="@+id/d2CinExpiry"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Expiration CIN" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/d2Birthdate"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Naissance" />

                <EditText
                    android:id="@+id/d2Profession"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:hint="Profession" />
            </LinearLayout>

            <EditText
                android:id="@+id/d2Permit"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Numero permis" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/d2PermitDate"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Date permis" />

                <EditText
                    android:id="@+id/d2PermitPlace"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:hint="Lieu permis" />
            </LinearLayout>

            <EditText
                android:id="@+id/d2Phone"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Telephone"
                android:inputType="phone" />

            <EditText
                android:id="@+id/d2Address"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Adresse" />

            <EditText
                android:id="@+id/d2Ville"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Ville" />

            <View style="@style/ContractFormDivider" />

            <TextView
                style="@style/ContractFormSection"
                android:text="CAUTION / CHEQUE" />

            <EditText
                android:id="@+id/checkNumber"
                style="@style/ContractFormInput"
                android:layout_marginTop="6dp"
                android:hint="Numero cheque" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/checkBank"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:hint="Banque" />

                <EditText
                    android:id="@+id/checkAmount"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:hint="Montant"
                    android:inputType="numberDecimal" />
            </LinearLayout>

            <View style="@style/ContractFormDivider" />

            <TextView
                style="@style/ContractFormSection"
                android:text="HORAIRES" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/heureDepart"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Heure depart" />

                <EditText
                    android:id="@+id/heureRetour"
                    style="@style/ContractFormInput"
                    android:layout_width="0dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Heure retour" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/navy"
                android:text="Creer le contrat"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:icon="@drawable/ic_contract"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/navy"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
