<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/navy"
        app:title="@string/new_reservation"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Vehicle spinner -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/vehicle" android:textColor="@color/ink" android:textSize="13sp" android:textStyle="bold" />
            <Spinner
                android:id="@+id/vehicleSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg" />

            <!-- Client spinner -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/client" android:textColor="@color/ink" android:textSize="13sp" android:textStyle="bold" />
            <Spinner
                android:id="@+id/clientSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg" />

            <!-- Date start -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Date début" android:textColor="@color/ink" android:textSize="13sp" android:textStyle="bold" />
            <EditText
                android:id="@+id/dateStart"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="10dp"
                android:focusable="false"
                android:clickable="true"
                android:hint="YYYY-MM-DD"
                android:textSize="14sp" />

            <!-- Date end -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Date fin" android:textColor="@color/ink" android:textSize="13sp" android:textStyle="bold" />
            <EditText
                android:id="@+id/dateEnd"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="10dp"
                android:focusable="false"
                android:clickable="true"
                android:hint="YYYY-MM-DD"
                android:textSize="14sp" />

            <!-- Total -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/total" android:textColor="@color/ink" android:textSize="13sp" android:textStyle="bold" />
            <EditText
                android:id="@+id/totalAmount"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:inputType="numberDecimal"
                android:paddingHorizontal="10dp"
                android:hint="0"
                android:textSize="14sp" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/navy"
                android:text="@string/save"
                android:textColor="@color/white"
                android:textAllCaps="true" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/navy"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
