<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="28dp">

            <!-- ── Header ─────────────────────────────────────────────── -->
            <TextView
                android:id="@+id/greeting"
                style="@style/ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aujourd’hui" />

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <!-- ── Spine: what needs attention now ────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/attentionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/warning_soft"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:rippleColor="@color/booking_yellow"
                app:strokeColor="@color/booking_yellow"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:contentDescription="@string/attention"
                        android:src="@drawable/ic_alert" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="13dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/attentionCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Rien d’urgent"
                            android:textColor="@color/ink"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/attentionText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxLines="3"
                            android:textColor="@color/muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/open"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Primary action ─────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/newReservation"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/blue_action"
                android:text="Nouvelle réservation"
                android:textColor="@color/white"
                android:textSize="15sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_plus"
                app:iconTint="@color/white" />

            <!-- ── Today's operations ─────────────────────────────────── -->
            <TextView
                style="@style/SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Opérations du jour" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <!-- Départs (pickups) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/pickupsCard"
                    style="@style/AppCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:rippleColor="@color/navy_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardBackgroundColor="@color/blue_soft"
                            app:cardCornerRadius="21dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/pickups_today"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/navy" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/pickups"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="0"
                                android:textColor="@color/ink"
                                android:textSize="26sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Départs"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Retours (returns) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/returnsCard"
                    style="@style/AppCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:rippleColor="@color/navy_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardBackgroundColor="@color/success_soft"
                            app:cardCornerRadius="21dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/returns_today"
                                android:src="@drawable/ic_flag"
                                app:tint="@color/green" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/returns"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="0"
                                android:textColor="@color/ink"
                                android:textSize="26sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Retours"
                                android:textColor="@color/muted"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Money: one focal finance block ─────────────────────── -->
            <TextView
                style="@style/SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/finance_month" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/navy"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/monthRevenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/white"
                        android:textSize="30sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">
                        <TextView android:id="@+id/weekRevenue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="@color/navy_light" android:textSize="12sp" />
                        <TextView android:id="@+id/todayRevenue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="@color/navy_light" android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Per-car breakdown (white card — rows use dark text/bars) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AppCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="15dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Revenu par voiture"
                        android:textColor="@color/ink"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/financePerCarList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/financeEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="12dp"
                        android:text="Aucune donnée pour cette période"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Fleet status: slim strip, not a card ───────────────── -->
            <TextView
                style="@style/SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/fleet_status" />

            <TextView
                android:id="@+id/fleetStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <!-- ── Secondary destinations (no bottom-nav entry) ───────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ctaClients"
                    style="@style/AppCard"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:rippleColor="@color/navy_light">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="15dp">
                        <ImageView android:layout_width="26dp" android:layout_height="26dp" android:contentDescription="@string/tab_clients" android:src="@drawable/ic_clients" app:tint="@color/navy" />
                        <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tab_clients" android:textColor="@color/ink" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ctaFinance"
                    style="@style/AppCard"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:rippleColor="@color/navy_light">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="15dp">
                        <ImageView android:layout_width="26dp" android:layout_height="26dp" android:contentDescription="@string/reports_title" android:src="@drawable/ic_dashboard" app:tint="@color/navy" />
                        <Space android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/reports_title" android:textColor="@color/ink" android:textSize="15sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/navy"
        android:visibility="gone" />
</FrameLayout>
