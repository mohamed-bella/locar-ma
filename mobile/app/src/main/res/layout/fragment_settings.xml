<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/logo"
                        android:layout_width="66dp"
                        android:layout_height="66dp"
                        android:background="@drawable/image_placeholder"
                        android:contentDescription="logo"
                        android:scaleType="centerInside" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_title"
                            android:textColor="@color/ink"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/role"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textColor="@color/muted"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_title"
                        android:textColor="@color/ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/agencyName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/agency_name"
                        android:inputType="textCapWords"
                        android:paddingHorizontal="12dp" />

                    <EditText
                        android:id="@+id/whatsappNumber"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/whatsapp_number"
                        android:inputType="phone"
                        android:paddingHorizontal="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/whatsappEnabled"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:text="@string/whatsapp_enabled"
                        android:textColor="@color/ink"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legal_info"
                        android:textColor="@color/ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/legalName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/input_bg"
                        android:hint="Raison sociale"
                        android:paddingHorizontal="12dp" />

                    <EditText
                        android:id="@+id/companyPhone"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:hint="@string/company_phone"
                        android:inputType="phone"
                        android:paddingHorizontal="12dp" />

                    <EditText
                        android:id="@+id/address"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:gravity="top"
                        android:hint="@string/agency_address"
                        android:padding="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/ice"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="ICE"
                            android:paddingHorizontal="12dp" />

                        <EditText
                            android:id="@+id/rc"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="5dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_bg"
                            android:hint="RC"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/rib"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_bg"
                        android:hint="RIB"
                        android:paddingHorizontal="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Notifications card ────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notif_section_title"
                        android:textColor="@color/ink"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/notif_section_desc"
                        android:textColor="@color/muted"
                        android:textSize="12sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/notifEnabled"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:checked="true"
                        android:text="@string/notif_enable"
                        android:textColor="@color/ink"
                        android:textSize="14sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginVertical="6dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/notifReservations"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:checked="true"
                        android:text="@string/notif_reservations"
                        android:textColor="@color/ink"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/notifSignatures"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:checked="true"
                        android:text="@string/notif_signatures"
                        android:textColor="@color/ink"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/notifVehicles"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:checked="true"
                        android:text="@string/notif_vehicles"
                        android:textColor="@color/ink"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/blue_action"
                android:text="@string/save_settings"
                android:textColor="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/openSuivi"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/green"
                    android:text="@string/open_suivi"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/openClients"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/navy"
                    android:text="@string/open_clients"
                    android:textColor="@color/white" />
            </LinearLayout>

            <Button
                android:id="@+id/openReports"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/navy"
                android:text="@string/reports_title"
                android:textColor="@color/white" />
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/navy"
        android:visibility="gone" />
</FrameLayout>
