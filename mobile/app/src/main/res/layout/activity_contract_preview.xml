<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/navy"
        app:title="Aperçu du contrat"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="6dp">

        <!-- documentRoot rendered into PDF -->
        <LinearLayout
            android:id="@+id/documentRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white"
            android:padding="8dp">

            <!-- ── Header: logo + name (left) | ICE/RC block (right) ─── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">

                <!-- LEFT: logo image + agency name -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                    <ImageView
                        android:id="@+id/agencyLogo"
                        android:layout_width="56dp"
                        android:layout_height="40dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitStart"
                        android:contentDescription="logo"
                        android:visibility="gone" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:layout_marginStart="6dp">
                        <TextView android:id="@+id/agencyName" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/pdf_navy"
                            android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Location De Voiture" android:textColor="@color/pdf_muted"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- RIGHT: legal name + ICE / RC / Patente / RIB / GSM -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="end">
                    <TextView android:id="@+id/agencyLegalName" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/pdf_ink"
                        android:textSize="9sp" android:textStyle="bold" android:gravity="end" />
                    <TextView android:id="@+id/agencyLegalLines" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/pdf_muted"
                        android:textSize="7.5sp" android:gravity="end" android:lineSpacingExtra="1dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Title bar ───────────────────────────────────────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/pdf_title_bar" android:paddingVertical="5dp"
                android:paddingHorizontal="10dp" android:layout_marginTop="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Contrat de location — عقد الكراء"
                    android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/contractNo" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:background="@drawable/pdf_num_chip"
                    android:paddingVertical="2dp" android:paddingHorizontal="6dp"
                    android:textColor="@color/pdf_navy" android:textSize="9sp" android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- ── Two columns ─────────────────────────────────────────── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:weightSum="100" android:layout_marginTop="4dp">

                <!-- LEFT 61% -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="61" android:orientation="vertical" android:layout_marginEnd="5dp">

                    <!-- Client -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/pdf_section_box"
                        android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                            android:paddingVertical="3dp" android:paddingHorizontal="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Informations client"
                                android:textColor="@color/white" android:textSize="8.5sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="معلومات الزبون" android:textColor="@color/pdf_head_ar"
                                android:textSize="8.5sp" android:textStyle="bold" />
                        </LinearLayout>
                        <LinearLayout android:id="@+id/clientGrid" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="vertical"
                            android:padding="4dp" />
                    </LinearLayout>

                    <!-- 2nd driver -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/pdf_section_box">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                            android:paddingVertical="3dp" android:paddingHorizontal="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Informations 2ème conducteur"
                                android:textColor="@color/white" android:textSize="8.5sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="السائق الثاني" android:textColor="@color/pdf_head_ar"
                                android:textSize="8.5sp" android:textStyle="bold" />
                        </LinearLayout>
                        <LinearLayout android:id="@+id/d2Grid" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="vertical"
                            android:padding="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- RIGHT 39% -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="39" android:orientation="vertical">

                    <!-- Vehicle -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/pdf_section_box"
                        android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                            android:paddingVertical="3dp" android:paddingHorizontal="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Info. voiture"
                                android:textColor="@color/white" android:textSize="8.5sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="معلومات السيارة" android:textColor="@color/pdf_head_ar"
                                android:textSize="8.5sp" android:textStyle="bold" />
                        </LinearLayout>
                        <LinearLayout android:id="@+id/vehicleGrid" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="vertical"
                            android:padding="4dp" />
                    </LinearLayout>

                    <!-- Fuel -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/pdf_section_box"
                        android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                            android:paddingVertical="3dp" android:paddingHorizontal="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Carburant (départ)"
                                android:textColor="@color/white" android:textSize="8.5sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="الوقود" android:textColor="@color/pdf_head_ar"
                                android:textSize="8.5sp" android:textStyle="bold" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="5dp">
                            <LinearLayout android:id="@+id/fuelGauge" android:layout_width="match_parent"
                                android:layout_height="14dp" android:orientation="horizontal" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:layout_marginTop="2dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="0" android:textColor="@color/pdf_muted" android:textSize="7sp" />
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:gravity="center" android:text="1/4" android:textColor="@color/pdf_muted" android:textSize="7sp" />
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:gravity="center" android:text="1/2" android:textColor="@color/pdf_muted" android:textSize="7sp" />
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:gravity="center" android:text="3/4" android:textColor="@color/pdf_muted" android:textSize="7sp" />
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:gravity="end" android:text="1" android:textColor="@color/pdf_muted" android:textSize="7sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Réglement -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:background="@drawable/pdf_section_box">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                            android:paddingVertical="3dp" android:paddingHorizontal="6dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Réglement"
                                android:textColor="@color/white" android:textSize="8.5sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="الأداء" android:textColor="@color/pdf_head_ar"
                                android:textSize="8.5sp" android:textStyle="bold" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="5dp">
                            <LinearLayout android:id="@+id/reglementGrid" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:orientation="vertical" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:gravity="center_horizontal"
                                android:background="@drawable/pdf_title_bar" android:paddingVertical="4dp"
                                android:paddingHorizontal="6dp" android:layout_marginTop="2dp">
                                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:orientation="horizontal">
                                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:text="Totale à payer"
                                        android:textColor="@color/pdf_head_ar" android:textSize="8sp" android:textStyle="bold" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="المبلغ الإجمالي" android:textColor="@color/pdf_head_ar"
                                        android:textSize="8sp" android:textStyle="bold" />
                                </LinearLayout>
                                <TextView android:id="@+id/totalValue" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:layout_marginTop="1dp"
                                    android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Fait à … le … -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="end|center_vertical"
                android:layout_marginTop="5dp">
                <TextView android:id="@+id/faitLabel" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/pdf_ink"
                    android:textSize="9sp" android:textStyle="bold" android:layout_marginEnd="5dp" />
                <TextView android:id="@+id/faitValue" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:background="@drawable/pdf_value_box"
                    android:paddingVertical="2dp" android:paddingHorizontal="10dp"
                    android:textColor="@color/pdf_ink" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>

            <!-- Signatures -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="5dp" android:baselineAligned="false">

                <!-- Client signature -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:layout_marginEnd="5dp" android:orientation="vertical"
                    android:background="@drawable/pdf_section_box" android:minHeight="100dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                        android:paddingVertical="3dp" android:paddingHorizontal="5dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Signature du client"
                            android:textColor="@color/white" android:textSize="8sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="إمضاء الزبون" android:textColor="@color/pdf_head_ar" android:textSize="8sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="4dp" android:textColor="@color/pdf_muted" android:textSize="7sp"
                        android:lineSpacingExtra="0.5dp"
                        android:text="Je reconnais avoir pris connaissance des informations du présent contrat et j\'accepte l\'ensemble de ses conditions.\nاعترف باني قرأت المعلومات الواردة في هذا العقد، وأوافق على جميع ما جاء فيها." />
                    <!-- Actual signed image (shown when client has signed via web link) -->
                    <ImageView android:id="@+id/clientSignImg" android:layout_width="match_parent"
                        android:layout_height="60dp" android:layout_margin="4dp" android:adjustViewBounds="true"
                        android:scaleType="fitCenter" android:visibility="gone"
                        android:contentDescription="Signature client" />
                    <TextView android:id="@+id/clientSign" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:paddingHorizontal="5dp" android:paddingBottom="4dp"
                        android:textColor="@color/pdf_muted" android:textSize="7.5sp" />
                </LinearLayout>

                <!-- 2nd driver signature -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:layout_marginEnd="5dp" android:orientation="vertical"
                    android:background="@drawable/pdf_section_box" android:minHeight="100dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                        android:paddingVertical="3dp" android:paddingHorizontal="5dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Signature 2ème conduc."
                            android:textColor="@color/white" android:textSize="8sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="إمضاء السائق الثاني" android:textColor="@color/pdf_head_ar" android:textSize="8sp" android:textStyle="bold" />
                    </LinearLayout>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:paddingHorizontal="5dp" android:paddingTop="4dp"
                        android:text="Nom complet : ......................."
                        android:textColor="@color/pdf_muted" android:textSize="8sp" />
                </LinearLayout>

                <!-- Agency stamp -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@drawable/pdf_section_box" android:minHeight="100dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="@drawable/pdf_head_bg"
                        android:paddingVertical="3dp" android:paddingHorizontal="5dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Cachet de l\'agence"
                            android:textColor="@color/white" android:textSize="8sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="طابع الشركة" android:textColor="@color/pdf_head_ar" android:textSize="8sp" android:textStyle="bold" />
                    </LinearLayout>
                    <ImageView android:id="@+id/stampImage" android:layout_width="match_parent"
                        android:layout_height="0dp" android:layout_weight="1" android:layout_margin="5dp"
                        android:adjustViewBounds="true" android:scaleType="fitCenter"
                        android:visibility="gone" android:contentDescription="Cachet" />
                </LinearLayout>
            </LinearLayout>

            <!-- Footer -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/pdf_line" android:layout_marginTop="6dp" />
            <TextView android:id="@+id/footerText" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:gravity="center" android:paddingTop="4dp"
                android:textColor="@color/pdf_muted" android:textSize="7sp" android:lineSpacingExtra="0.5dp" />
        </LinearLayout>
    </ScrollView>

    <!-- CTA bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="@color/card_bg">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/shareButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:backgroundTint="@color/muted"
            android:text="Partager"
            android:textColor="@color/white"
            app:icon="@drawable/ic_share"
            app:iconSize="26dp"
            app:iconGravity="textStart"
            app:iconTint="@color/white" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/downloadButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:backgroundTint="@color/navy"
            android:text="PDF"
            android:textColor="@color/white"
            app:icon="@drawable/ic_download"
            app:iconSize="26dp"
            app:iconGravity="textStart"
            app:iconTint="@color/white" />
    </LinearLayout>

    <ProgressBar android:id="@+id/progress" android:layout_width="28dp" android:layout_height="28dp"
        android:layout_gravity="center" android:indeterminateTint="@color/navy" android:visibility="gone" />
</LinearLayout>
