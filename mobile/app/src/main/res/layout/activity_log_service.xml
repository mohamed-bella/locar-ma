<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/navy"
        app:title="@string/new_service_record"
        app:titleTextColor="@color/white"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vehicle"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:textStyle="bold" />
            <Spinner
                android:id="@+id/vehicleSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Type"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:textStyle="bold" />
            <Spinner
                android:id="@+id/typeSpinner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Date"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/performedAt"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_bg"
                android:clickable="true"
                android:focusable="false"
                android:hint="YYYY-MM-DD"
                android:paddingHorizontal="10dp"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">
                <EditText
                    android:id="@+id/odometerKm"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/input_bg"
                    android:hint="Km"
                    android:inputType="number"
                    android:paddingHorizontal="10dp"
                    android:textSize="14sp" />
                <EditText
                    android:id="@+id/cost"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/input_bg"
                    android:hint="Coût"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="10dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/garage"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg"
                android:hint="Garage"
                android:paddingHorizontal="10dp"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/nextDueKm"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg"
                android:hint="Prochain km"
                android:inputType="number"
                android:paddingHorizontal="10dp"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/nextDueDate"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg"
                android:clickable="true"
                android:focusable="false"
                android:hint="Prochaine date"
                android:paddingHorizontal="10dp"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/notes"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_bg"
                android:gravity="top"
                android:hint="Notes"
                android:padding="10dp"
                android:textSize="14sp" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/navy"
                android:text="@string/save_followup"
                android:textColor="@color/white"
                android:textAllCaps="true" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:indeterminateTint="@color/navy"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
