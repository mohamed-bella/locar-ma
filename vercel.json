{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "regions": ["dub1"],
  "functions": {
    "api/server.mjs": {
      "includeFiles": "{dist/server/**,public/fonts/**}"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/api/server" }
  ]
}
