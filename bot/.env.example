# Supabase connection (service role — bypasses RLS to read notification_queue)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# R2 public URL base (to download PDFs for sending as attachments)
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Daily report hour (0-23, Casablanca time). Sends a fleet/reservations/contracts
# digest to each agency's WhatsApp number. Leave empty to disable. e.g. 8 = 08:00
REPORT_HOUR=8
